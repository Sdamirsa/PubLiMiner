# PubLiMiner Environment Variables
# Copy this file to .env and fill in your values.

# PubMed API (optional but increases rate limit from 1 to 10 req/sec)
NCBI_API_KEY=
PUBMED_EMAIL=your.email@example.com

# OpenRouter API (for embeddings and LLM extraction)
OPENROUTER_API_KEY=

# Patent API (optional, for patent linking step)
PATENT_API_KEY=
